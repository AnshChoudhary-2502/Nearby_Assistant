# Anthropic (Claude) API key — used as the LLM/agent brain
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Maps Platform API key
# Enable "Places API (New)" and "Geocoding API" for this key in
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Gmail Assistant (gmail/app.py) — OAuth client for a Desktop App,
# downloaded from https://console.cloud.google.com/apis/credentials
# with the Gmail API enabled. Defaults to credentials.json / token.json
# inside the gmail/ directory if these are left unset.
GMAIL_CREDENTIALS_FILE=gmail/credentials.json
GMAIL_TOKEN_FILE=gmail/token.json

# Calendar Assistant (calendar_assistant/app.py) — OAuth client for a
# Desktop App, downloaded from https://console.cloud.google.com/apis/credentials
# with the Google Calendar API enabled. Defaults to credentials.json / token.json
# inside the calendar_assistant/ directory if these are left unset.
CALENDAR_CREDENTIALS_FILE=calendar_assistant/credentials.json
CALENDAR_TOKEN_FILE=calendar_assistant/token.json
